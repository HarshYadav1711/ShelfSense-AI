DJANGO_SECRET_KEY=replace-with-secure-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Database mode
# - Leave USE_MYSQL unset/false to use SQLite for frictionless local setup.
# - Set USE_MYSQL=1 and provide a real MYSQL_PASSWORD to run the full MySQL-backed stack.
USE_MYSQL=0

MYSQL_DATABASE=shelfsense
MYSQL_USER=root
MYSQL_PASSWORD=your-local-password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# MySQL 8 default auth (`caching_sha2_password`) requires the `cryptography` package when using PyMySQL.
CORS_ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_MODEL=llama3.1:8b
OLLAMA_URL=http://localhost:11434
LMSTUDIO_URL=http://localhost:1234
LOCAL_LLM_TIMEOUT_SECONDS=45

EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=backend/.chroma
CHROMA_COLLECTION_NAME=shelfsense-book-chunks
